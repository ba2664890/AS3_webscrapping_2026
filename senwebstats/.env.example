# ================================================================
# SenWebStats — Variables d'environnement
# ================================================================
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir les valeurs ci-dessous
# 3. NE PAS committer le fichier .env (il est dans .gitignore)
# ================================================================

# ── OPTION A : DataForSEO (RECOMMANDÉ — le plus abordable) ──────
# Inscription gratuite sur https://app.dataforseo.com/register
# Crédits offerts : $1 gratuit sans carte bancaire
# Coût estimé pour 28 sites : ~$0.06 par analyse complète
# Documentation : https://docs.dataforseo.com/
DATAFORSEO_LOGIN=votre_email@exemple.com
DATAFORSEO_PASSWORD=votre_mot_de_passe

# ── OPTION B : Semrush (le plus complet, mais payant) ───────────
# Inscription sur https://www.semrush.com/
# Essai gratuit 7 jours, puis Pro à ~129$/mois
# Clé API disponible dans : Mon compte > Profil > API
# Documentation : https://developer.semrush.com/
SEMRUSH_API_KEY=votre_cle_api_semrush

# ── OPTION C : Serper.dev (RECOMMANDÉ — accepte Gmail, le plus simple) ───────
# Inscription GRATUITE avec Gmail : https://serper.dev → "Sign up with Google"
# 2 500 recherches/mois gratuites (sans carte bancaire)
# Coût estimé pour 28 sites × 10 mots-clés = 280 req → 100% gratuit
# Récupère les vraies positions Google Sénégal (gl=sn)
# Clé API disponible sur : https://serper.dev → Dashboard → API Key
SERPER_API_KEY=votre_cle_serper

# ── OPTION D : Open PageRank (gratuit, pas de carte bancaire) ──────────
# Inscription gratuite (n'importe quel email) : https://www.domcop.com/openpagerank/
# Cliquer "Get Free API Key" → recevoir la clé par email
# Donne : score PageRank 0-10 + rang mondial pour chaque domaine
# Limite : 100 domaines/requête (largement suffisant pour 28 sites)
OPENPAGERANK_API_KEY=cs0g0k8k4s804wso4w8ow8ccww0c8o8ww48kog40 

# ── CONFIG DASHBOARD ────────────────────────────────────────────
# Port du serveur Dash (défaut : 8050)
PORT=8050
# Mode debug (true = rechargement auto, false = production)
DASH_DEBUG=false
